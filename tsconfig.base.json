{
  "compilerOptions": {
    "target": "ES2023",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@immersion/contracts": ["packages/contracts/src/index.ts"],
      "@immersion/contracts/*": ["packages/contracts/src/*"],
      "@immersion/domain": ["packages/domain/src/index.ts"],
      "@immersion/domain/*": ["packages/domain/src/*"],
      "@immersion/test-utils": ["packages/test-utils/src/index.ts"],
      "@immersion/test-utils/*": ["packages/test-utils/src/*"]
    }
  }
}
