{
  "name": "immersion-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop ecosystem.config.cjs",
    "restart": "pm2 restart ecosystem.config.cjs",
    "logs": "pm2 logs",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "lint": "biome check ./client/src ./server/src",
    "lint:fix": "biome check --write ./client/src ./server/src",
    "format": "biome format --write ./client/src ./server/src",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "cd client && npm run typecheck",
    "typecheck:server": "cd server && npm run typecheck",
    "check": "npm run lint && npm run typecheck && npm run build:client && npm run build:server",
    "validate": "npm run check",
    "ci:verify": "npm run check",
    "rewrite:install": "corepack pnpm install",
    "rewrite:dev:api": "corepack pnpm --filter @immersion/api dev",
    "rewrite:dev:web": "corepack pnpm --filter @immersion/web dev",
    "rewrite:lint": "biome check ./apps ./packages",
    "rewrite:lint:fix": "biome check --write ./apps ./packages",
    "rewrite:typecheck": "corepack pnpm -r typecheck",
    "rewrite:build": "corepack pnpm -r build",
    "rewrite:test": "corepack pnpm -r --if-present test",
    "rewrite:smoke": "corepack pnpm --filter @immersion/web test:smoke",
    "rewrite:check": "npm run rewrite:lint && npm run rewrite:typecheck && npm run rewrite:build && npm run rewrite:test",
    "rewrite:ci": "npm run rewrite:check && npm run rewrite:smoke",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.1.7"
  }
}
