# Dependencies
node_modules/
.pnpm-store/

# Keep lockfiles versioned for deterministic installs and CI
!package-lock.json
!client/package-lock.json
!server/package-lock.json

# Build output
server/dist/
client/dist/
apps/*/dist/
packages/*/dist/
apps/web/playwright-report/
apps/web/test-results/
*.tsbuildinfo
.turbo/

# User data (chats, characters, settings, etc.)
/data/

# Binary files
bin/
*.exe
models/

# Environment & secrets
.env
secrets.json
config.yaml

# Editors & tools
.vscode/
.idea/
*.code-workspace
.DS_Store

# Dev artifacts
.claude/
.codex/
.aider*
CLAUDE.md
ROADMAP.md
/docs/

# Logs
*.log
content.log
access.log

# OS
nul
Thumbs.db
